# ============================================================
# HACCP Monitor — Configuration environment
# ============================================================
# Ce fichier est chargé au démarrage par python-dotenv.
# Ne jamais committer sur Git.

# ---- MQTT (Mosquitto / Zigbee2MQTT) -------------------------
# Mettre l'IP de la machine qui héberge Mosquitto (ex : Raspberry Pi)
# Vérifier l'IP dans l'interface Zigbee2MQTT (Paramètres → MQTT)
MQTT_BROKER=192.168.1.83
MQTT_PORT=1883
MQTT_TOPIC=zigbee2mqtt/#
DELAI_PERTE_SIGNAL_S=900

# ---- Serveur ------------------------------------------------
PORT=8081
HOST=0.0.0.0

# ---- Email SMTP (laisser vide pour désactiver) --------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ---- SMS OVH (laisser vide pour désactiver) -----------------
OVH_APP_KEY=
OVH_APP_SECRET=
OVH_CONSUMER_KEY=
OVH_SMS_ACCOUNT=
OVH_SMS_SENDER=HACCP
