# Copier ce fichier en .env et renseigner les valeurs
# Ne jamais committer .env sur Git

# MQTT
MQTT_BROKER=localhost
MQTT_PORT=1883
DELAI_PERTE_SIGNAL_S=900   # 15 minutes

# Email SMTP (ex: compte Gmail dédié)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=haccp@mondomaine.fr
SMTP_PASSWORD=mot_de_passe_application
SMTP_FROM=haccp@mondomaine.fr

# SMS OVH (laisser vide pour désactiver)
OVH_APP_KEY=
OVH_APP_SECRET=
OVH_CONSUMER_KEY=
OVH_SMS_ACCOUNT=
OVH_SMS_SENDER=HACCP
