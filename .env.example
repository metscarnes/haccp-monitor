# Copier ce fichier en .env et renseigner les valeurs
# Ne jamais committer .env sur Git

# Environnement : mettre "production" sur le serveur (Raspberry).
# En production : /docs masqué, cookie de session sécurisé (HTTPS), et
# l'application REFUSE de démarrer si JWT_SECRET garde sa valeur par défaut.
ENV=production

# Origines autorisées pour le CORS (séparées par des virgules).
# Laisser vide si la SPA et l'API sont sur le même domaine (cas normal).
# CORS_ORIGINS=http://ulyssetest.ddns.net

# MQTT
MQTT_BROKER=localhost
MQTT_PORT=1883
DELAI_PERTE_SIGNAL_S=900   # 15 minutes

# Authentification admin
# ⚠️ Choisir un mot de passe long et aléatoire (≥ 16 caractères), sans lien
#    avec un nom de famille ou le nom de la boutique (cf. audit A-3).
ADMIN_PASSWORD=remplacer-par-un-mot-de-passe-fort-aleatoire
# ⚠️ Générer un secret unique :
#    python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=remplacer-par-un-secret-aleatoire-genere

# Email SMTP (compte Gmail dédié avec mot de passe d'application)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=metscarnes@gmail.com
SMTP_PASSWORD=mot_de_passe_application_16_caracteres

# Email destinataire pour les alertes et réinitialisation de mot de passe
ADMIN_EMAIL=ucampiglia@gmail.com

# URL publique de l'application (pour les liens dans les mails)
APP_URL=http://ulyssetest.ddns.net

# SMS OVH (laisser vide pour désactiver)
OVH_APP_KEY=
OVH_APP_SECRET=
OVH_CONSUMER_KEY=
OVH_SMS_ACCOUNT=
OVH_SMS_SENDER=HACCP
